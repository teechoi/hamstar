# ═══════════════════════════════════════════════════════════════════════════════
# Hamstar — Environment Variables
# ───────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's already in .gitignore).
# ═══════════════════════════════════════════════════════════════════════════════


# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → Database → Connection string
# 3. Go to Project Settings → API for the keys below

# Pooling connection (used by the app at runtime — port 6543)
DATABASE_URL="postgresql://postgres.YOURPROJECTREF:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (used by Prisma migrations — port 5432)
DIRECT_URL="postgresql://postgres.YOURPROJECTREF:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Project URL and anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOURPROJECTREF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role key — server-side only, NEVER expose publicly
SUPABASE_SERVICE_ROLE_KEY="eyJ..."


# ─── HELIUS (Solana indexer) ────────────────────────────────────────────────────
# 1. Create an account at https://dev.helius.xyz
# 2. Create an API key → paste below
# 3. Pick any random string for the webhook secret (used to verify incoming webhooks)
#    Generate one: openssl rand -hex 32

HELIUS_API_KEY="YOUR_HELIUS_API_KEY"
HELIUS_WEBHOOK_SECRET="YOUR_RANDOM_WEBHOOK_SECRET"


# ─── PET WALLET ADDRESSES ──────────────────────────────────────────────────────
# Create 3 Solana wallets (Phantom app → create wallet → copy public address).
# These are the addresses fans send SOL to when supporting a racer.
# ⚠️  Keep the private keys secure — only the public addresses go here.

DASH_WALLET="DASH_PUBLIC_WALLET_ADDRESS"
FLASH_WALLET="FLASH_PUBLIC_WALLET_ADDRESS"
TURBO_WALLET="TURBO_PUBLIC_WALLET_ADDRESS"


# ─── RACE SCHEDULE ─────────────────────────────────────────────────────────────
# Unix timestamp (milliseconds) for when Race #1 starts.
# Generate: new Date('2025-04-01T18:00:00Z').getTime()
# Races run every 48 hours from this point automatically.

GENESIS_TIMESTAMP="YOUR_LAUNCH_TIMESTAMP_IN_MS"


# ─── DEPLOYMENT ────────────────────────────────────────────────────────────────
# Your live domain — used by setup-helius to register the webhook URL.
# In development this isn't needed (Helius can't reach localhost).

NEXT_PUBLIC_SITE_URL="https://your-domain.com"


# ─── ADMIN PANEL ───────────────────────────────────────────────────────────────
# Generate a bcrypt hash of your password:
#   node -e "const b=require('bcryptjs'); b.hash('yourpassword',10).then(console.log)"
# Paste the resulting hash (starts with $2b$) below — never store the raw password.
ADMIN_PASSWORD_HASH="$2b$10$..."

# Random 32+ character string to sign admin session cookies.
# Generate: openssl rand -hex 32
ADMIN_SESSION_SECRET="your-random-32-char-secret-here"


# ─── CLOUDINARY (media uploads) ────────────────────────────────────────────────
# Sign up at cloudinary.com (free tier). Find these in Dashboard → API Keys.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
