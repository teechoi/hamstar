# ═══════════════════════════════════════════════════════════════════════════
# HamstarHub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════════════

# ─── SUPABASE ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API

# Used by Prisma (connection pooling via pgBouncer — use for app queries)
DATABASE_URL="postgresql://postgres.YOURPROJECTREF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Used by Prisma migrations (direct connection, bypasses pgBouncer)
DIRECT_URL="postgresql://postgres.YOURPROJECTREF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Public keys — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL="https://YOURPROJECTREF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role key — NEVER expose publicly, server-side only
SUPABASE_SERVICE_ROLE_KEY="eyJ..."


# ─── HELIUS (Solana Indexer) ─────────────────────────────────────────────────
# Get from: https://dev.helius.xyz → API Keys

HELIUS_API_KEY="your-helius-api-key"

# A random secret string you choose — must match what you set in Helius webhook
# Generate one: openssl rand -hex 32
HELIUS_WEBHOOK_SECRET="your-random-secret-string"


# ─── PET WALLET ADDRESSES ────────────────────────────────────────────────────
# Create 3 Phantom wallets, paste the PUBLIC addresses here.
# These are the addresses donors send SOL to.

HAMMY_WALLET="HammyWalletPublicAddressHere"
WHISKERS_WALLET="WhiskersWalletPublicAddressHere"
NUGGET_WALLET="NuggetWalletPublicAddressHere"


# ─── RACE SCHEDULE ───────────────────────────────────────────────────────────
# Unix timestamp (ms) of when Race #1 starts.
# Generate: new Date('2024-03-01T18:00:00Z').getTime()

GENESIS_TIMESTAMP="1709316000000"


# ─── SITE CONFIG ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://hamstarhub.xyz"
NEXT_PUBLIC_YOUTUBE_URL="https://youtube.com/@hamstarhub"
