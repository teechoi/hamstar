// HamstarHub — Prisma Schema
// DB: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── PETS ─────────────────────────────────────────────────────────────────────
model Pet {
  id            String  @id @default(cuid())
  slug          String  @unique         // "dash" | "flash" | "turbo"
  name          String
  number        String                  // "07" | "03" | "99"
  emoji         String
  team          String
  tagline       String
  color         String                  // hex e.g. "#FF3B5C"
  walletAddress String  @unique         // Solana address for donations
  active        Boolean @default(true)
  bio           String  @default("")
  image         String  @default("")
  wins          Int     @default(0)

  // Base stats (0-100)
  speedBase     Int     @default(50)
  chaosBase     Int     @default(50)

  // Lifestyle (computed from upgrades)
  snackLevel    Int     @default(20)
  cageLevel     Int     @default(20)

  sponsors    Sponsor[]
  donations   Donation[]
  raceEntries RaceEntry[]
  upgrades    PetUpgrade[]
  cheers      Cheer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pets")
}

// ─── RACES ────────────────────────────────────────────────────────────────────
model Race {
  id       String     @id @default(cuid())
  number   Int        @unique
  status   RaceStatus @default(UPCOMING)
  startsAt DateTime
  endsAt   DateTime
  title    String?
  recap    String?

  // ── On-chain state ─────────────────────────────────────────────────────
  /// u64 race_id used for on-chain PDA seeds (= race.number by convention)
  onChainRaceId   BigInt?
  /// Escrow token account address (PDA["race_escrow", race_id_le])
  escrowAddress   String?
  /// True once create_race instruction was successfully sent
  onChainCreated  Boolean @default(false)
  /// True once the race is Settled on-chain (2-of-3 settler consensus reached)
  onChainSettled  Boolean @default(false)

  entries   RaceEntry[]
  donations Donation[]
  cheers    Cheer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("races")
}

model RaceEntry {
  id       String   @id @default(cuid())
  raceId   String
  petId    String
  position Int?                               // 1/2/3 — null until finished
  totalSol Decimal  @default(0) @db.Decimal(18, 9)

  race Race @relation(fields: [raceId], references: [id])
  pet  Pet  @relation(fields: [petId], references: [id])

  @@unique([raceId, petId])
  @@map("race_entries")
}

enum RaceStatus {
  UPCOMING
  LIVE
  FINISHED
}

// ─── DONATIONS ────────────────────────────────────────────────────────────────
model Donation {
  id            String       @id @default(cuid())
  txSignature   String       @unique       // Solana tx signature (dedup key)
  petId         String
  raceId        String?
  walletAddress String                     // sender's wallet
  alias         String?                    // from tx memo
  amountSol     Decimal      @db.Decimal(18, 9)
  type          DonationType @default(RACE_SUPPORT)
  confirmedAt   DateTime

  pet  Pet   @relation(fields: [petId], references: [id])
  race Race? @relation(fields: [raceId], references: [id])

  createdAt DateTime @default(now())

  @@index([petId])
  @@index([raceId])
  @@map("donations")
}

enum DonationType {
  RACE_SUPPORT
  SNACK
  CAGE
  ARENA_FUND
  SPONSOR
}

// ─── SPONSORS ─────────────────────────────────────────────────────────────────
model Sponsor {
  id            String      @id @default(cuid())
  name          String
  emoji         String      @default("🏆")
  petId         String?
  tier          SponsorTier
  solPerRace    Decimal     @db.Decimal(18, 9)
  walletAddress String?
  websiteUrl    String?
  active        Boolean     @default(true)

  pet Pet? @relation(fields: [petId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sponsors")
}

enum SponsorTier {
  SILVER
  GOLD
  TITLE
}

// ─── UPGRADES ─────────────────────────────────────────────────────────────────
model UpgradeItem {
  id          String          @id @default(cuid())
  category    UpgradeCategory
  tier        UpgradeTier
  name        String
  emoji       String
  description String
  costSol     Decimal         @db.Decimal(18, 9)
  sortOrder   Int             @default(0)

  petUpgrades PetUpgrade[]

  @@map("upgrade_items")
}

model PetUpgrade {
  id          String   @id @default(cuid())
  petId       String
  upgradeId   String
  unlockedAt  DateTime @default(now())

  pet     Pet         @relation(fields: [petId], references: [id])
  upgrade UpgradeItem @relation(fields: [upgradeId], references: [id])

  @@unique([petId, upgradeId])
  @@map("pet_upgrades")
}

enum UpgradeCategory {
  SNACK
  CAGE
}

enum UpgradeTier {
  BASIC
  UPGRADE
  ELITE
  LEGENDARY
}

// ─── MEDIA ────────────────────────────────────────────────────────────────────
model Media {
  id          String    @id @default(cuid())
  type        MediaType
  title       String
  description String?
  url         String
  thumbnail   String?
  duration    String?
  featured    Boolean   @default(false)
  publishedAt DateTime  @default(now())

  @@map("media")
}

enum MediaType {
  VIDEO
  PHOTO
}

// ─── USERS ────────────────────────────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique          // Solana public key — primary identity
  privyUserId   String?  @unique          // 'did:privy:...' — set when using embedded wallet
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cheers Cheer[]

  @@index([walletAddress])
  @@map("users")
}

// ─── CHEERS ───────────────────────────────────────────────────────────────────
model Cheer {
  id            String   @id @default(cuid())
  walletAddress String
  raceId        String
  petId         String
  won           Boolean?           // null until race finishes
  amountHamstar Float?             // HAMSTAR cheered (null for legacy / pre-launch entries)
  txSignature   String?  @unique    // place_cheer tx signature (null before token launch; unique prevents replay)

  // ── On-chain payout state ───────────────────────────────────────────────
  /// Time-weighted stake (from place_cheer instruction: amount × weight_bps / 1000)
  onChainWeight Float?
  /// True once push_reward or claim_reward was confirmed for this cheer
  rewardPushed  Boolean  @default(false)
  /// Amount of HAMSTAR tokens received as reward (null until pushed)
  rewardAmount  Float?

  createdAt     DateTime @default(now())

  user User @relation(fields: [walletAddress], references: [walletAddress])
  race Race @relation(fields: [raceId],        references: [id])
  pet  Pet  @relation(fields: [petId],         references: [id])

  @@unique([walletAddress, raceId])   // one cheer per user per race
  @@index([walletAddress])
  @@map("cheers")
}

// ─── SITE SETTINGS ────────────────────────────────────────────────────────────
model SiteSettings {
  id           String   @id @default("singleton")
  raceNumber   Int      @default(1)
  isLive       Boolean  @default(false)
  streamUrl    String   @default("")
  replayUrl    String?
  genesisTs    BigInt   @default(0)
  twitterUrl   String?
  tiktokUrl    String?
  instagramUrl String?
  youtubeUrl   String?
  sponsorEmail String   @default("")
  siteName     String   @default("Hamstar")
  tagline      String   @default("Who will be the Hamstar?")
  ogImageUrl   String?
  buttonLabels Json     @default("{}")

  // ── Editable front-end content ──────────────────────────────────────────
  navTagline    String  @default("The smallest sport on the internet.")

  // Hero
  heroTitle     String  @default("Who Will Be The Hamstar?")
  heroSubtitle  String  @default("Three hamsters race. One takes the wheel.")
  heroCtaTag    String  @default("Round 1 Coming Soon!")
  heroButtonText String @default("Watch Live Race")

  // Racers
  racersTitle   String  @default("Meet the Racers")

  // About
  aboutTitle    String  @default("About Hamstar")
  aboutText     String  @default("Hamstar is a tiny internet sport built around real hamster races.\n\nIn each race, three hamsters compete on a small track while the community watches the race live and cheers for their favourite racer.\n\nIt's simple, fast, and unpredictable, just like the hamsters themselves.")

  // Arena section
  arenaTitle      String @default("Hamstar Arena")
  arenaSubtitle   String @default("Hamstar races are streamed live on Pump.fun. Watch the race and return to see the winner.")
  arenaStreamNote String @default("Race will be streamed live on Pump.fun")

  // Footer
  footerTagline    String @default("The smallest sport on the internet.")
  footerBrandDesc  String @default("Live hamster racing powered by community participation")
  footerTaglineRight String @default("Real hamsters.\nReal races.\nOne tiny champion.")
  footerLinks      Json   @default("[]")

  // Modals
  loginTitle      String @default("Welcome to Hamstar Arena 🐹")
  loginSubtitle   String @default("A live-streamed blockchain-based entertainment experience")
  termsButtonText String @default("I Understand & Enter Arena")
  howitWorksSteps Json   @default("[]")

  // ── Token config (updated via admin settings, no redeploy needed) ────────
  hamstarMint        String @default("HAMSTARxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx")
  hamstarPoolAddress String @default("POOLxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx")

  updatedAt    DateTime @updatedAt

  @@map("site_settings")
}
